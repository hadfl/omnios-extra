. /lib/svc/share/smf_include.sh

if [ -z "$SMF_FMRI" ]; then
	echo "SMF framework variables are not initialised."
	exit $SMF_EXIT_ERR
fi

typeset -r ANUBIS="/$(PREFIX)/bin/$(PROG)"
typeset -r CONFDIR="/etc/$(PREFIX)"

instance="${2:-${SMF_FMRI##*:}}"
envfile="$CONFDIR/$instance.env"

case "$1" in
start)
	if [ ! -f "$envfile" ]; then
		print -u2 "Configuration file '$envfile' is missing."
		print -u2 "Copy $CONFDIR/default.env to '$envfile' and"\
		    "customise it for this instance."
		exit $SMF_EXIT_ERR_CONFIG
	fi

	# anubis is configured via environment variables; export everything
	# set in the instance environment file.
	set -a
	. "$envfile" || exit $SMF_EXIT_ERR_CONFIG
	set +a

	exec $ANUBIS 2>&1
	;;
*)
	echo "Unknown method."
	exit $SMF_EXIT_ERR_FATAL
	;;
esac

